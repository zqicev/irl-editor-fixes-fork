>>>
after "        screen.selection_box_outline = SELECT_BOX SELECT_BOX_COL_R SELECT_BOX_COL_G SELECT_BOX_COL_B"
<<<


######## IRLITE LIGHTS (BBS addon, injected by the IRLite patcher)
    screen.IRLITE_SETTINGS.columns = 1
    screen.IRLITE_SETTINGS = IRLITE_DIFFUSE IRLITE_INTENSITY <empty> [IRLITE_SPECULAR_SCREEN] [IRLITE_SHADOW_SCREEN] [IRLITE_VL_SCREEN] [IRLITE_TOON_SCREEN] [IRLITE_OUTLINE_SCREEN]

        screen.IRLITE_SPECULAR_SCREEN.columns = 1
        screen.IRLITE_SPECULAR_SCREEN = IRLITE_SPECULAR IRLITE_SPECULAR_INTENSITY IRLITE_SPECULAR_SMOOTHNESS

        screen.IRLITE_SHADOW_SCREEN.columns = 1
        screen.IRLITE_SHADOW_SCREEN = IRLITE_SHADOWS IRLITE_SHADOW_QUALITY IRLITE_SHADOW_SIZE IRLITE_SHADOW_BIAS IRLITE_SHADOW_NORMAL_OFFSET

        screen.IRLITE_VL_SCREEN.columns = 1
        screen.IRLITE_VL_SCREEN = IRLITE_VOLUMETRIC IRLITE_VL_INTENSITY IRLITE_VL_STEPS IRLITE_VL_MAX_DIST <empty> IRLITE_VL_SHADOWS IRLITE_VL_SHADOW_STRIDE <empty> IRLITE_VL_TIP_BOOST IRLITE_VL_TIP_RADIUS

        screen.IRLITE_TOON_SCREEN.columns = 1
        screen.IRLITE_TOON_SCREEN = IRLITE_TOON IRLITE_TOON_BANDS IRLITE_TOON_SMOOTH

        screen.IRLITE_OUTLINE_SCREEN.columns = 1
        screen.IRLITE_OUTLINE_SCREEN = IRLITE_OUTLINE IRLITE_OUTLINE_TARGET IRLITE_OUTLINE_STRENGTH IRLITE_OUTLINE_PIXEL_SIZE IRLITE_OUTLINE_WRAP IRLITE_OUTLINE_DEPTH_THRESHOLD
>>>
replace "LPV_SATURATION LPV_TINT_SATURATION LPV_NORMAL_STRENGTH"
<<<
LPV_SATURATION LPV_TINT_SATURATION LPV_NORMAL_STRENGTH IRLITE_INTENSITY IRLITE_SPECULAR_INTENSITY IRLITE_SPECULAR_SMOOTHNESS IRLITE_SHADOW_QUALITY IRLITE_SHADOW_SIZE IRLITE_SHADOW_BIAS IRLITE_SHADOW_NORMAL_OFFSET IRLITE_VL_SHADOW_STRIDE IRLITE_VL_INTENSITY IRLITE_VL_STEPS IRLITE_VL_TIP_BOOST IRLITE_VL_TIP_RADIUS IRLITE_VL_MAX_DIST IRLITE_TOON_BANDS IRLITE_TOON_SMOOTH IRLITE_OUTLINE_PIXEL_SIZE IRLITE_OUTLINE_STRENGTH IRLITE_OUTLINE_WRAP IRLITE_OUTLINE_DEPTH_THRESHOLD
>>>

# --- option labels + tooltips (English) ---
@file shaders/lang/en_us.lang
after "option.TRANSLUCENT_COLORED_SHADOWS.comment = §bWhat is this?§r This effect allows translucent things like stained glass to color the sunlight as it passes through it. §aPERFORMANCE COST:§r medium"
<<<

######## IRLITE LIGHTS (BBS addon, injected by the IRLite patcher)

screen.IRLITE_SETTINGS = §6IRLite Lights§r
screen.IRLITE_SETTINGS.comment = Dynamic point and spot lights from the IRLite BBS addon - diffuse, specular, baked shadows, volumetric beams, toon shading and rim outline.
screen.IRLITE_SPECULAR_SCREEN = §bIRLite Specular§r
screen.IRLITE_SHADOW_SCREEN = §3IRLite Shadows§r
screen.IRLITE_VL_SCREEN = §dIRLite Volumetric Light§r
screen.IRLITE_TOON_SCREEN = §aIRLite Toon Shading§r
screen.IRLITE_OUTLINE_SCREEN = §eIRLite Rim Outline§r

option.IRLITE_DIFFUSE = §6Diffuse Light§r
option.IRLITE_DIFFUSE.comment = Surface lighting from the IRLite point and spot lights.
option.IRLITE_INTENSITY = §6Master Intensity§r
option.IRLITE_INTENSITY.comment = Master brightness for all IRLite terms - diffuse, specular, volumetrics and the outline.

option.IRLITE_SPECULAR = §bSpecular Highlights§r
option.IRLITE_SPECULAR.comment = Per-light GGX highlights on entities, hand and block entities. Terrain stays matte on purpose.
option.IRLITE_SPECULAR_INTENSITY = §bSpecular Intensity§r
option.IRLITE_SPECULAR_SMOOTHNESS = §bSpecular Smoothness§r
option.IRLITE_SPECULAR_SMOOTHNESS.comment = Width of the highlight lobe. BBS models carry no material maps, so this global slider drives the response.

option.IRLITE_SHADOWS = §3Baked Shadows§r
option.IRLITE_SHADOWS.comment = Per-light shadows from the maps baked by the mod (spot atlas + point cube array). Also required for shadowed beams and the outline gating.
option.IRLITE_SHADOW_QUALITY = §3Shadow Quality§r
option.IRLITE_SHADOW_QUALITY.comment = PCSS tap counts. 0 = one hard tap, 4 = ultra soft.
value.IRLITE_SHADOW_QUALITY.0 = Hard (1 tap)
value.IRLITE_SHADOW_QUALITY.1 = Low
value.IRLITE_SHADOW_QUALITY.2 = Medium
value.IRLITE_SHADOW_QUALITY.3 = High
value.IRLITE_SHADOW_QUALITY.4 = Ultra
option.IRLITE_SHADOW_SIZE = §3Light Size (PCSS)§r
option.IRLITE_SHADOW_SIZE.comment = Apparent size of the light source for the penumbra. A per-light Bulb Size set in the editor overrides this.
option.IRLITE_SHADOW_BIAS = §3Depth Bias§r
option.IRLITE_SHADOW_NORMAL_OFFSET = §3Normal Offset§r
option.IRLITE_SHADOW_NORMAL_OFFSET.comment = Receiver nudge along the normal that hides the depth staircase (acne). 0 disables it AND the texel floors.

option.IRLITE_VOLUMETRIC = §dVolumetric Light§r
option.IRLITE_VOLUMETRIC.comment = Per-light beams and haze, marched inside the pack's own reduced-resolution fog pass.
option.IRLITE_VL_INTENSITY = §dVL Intensity§r
option.IRLITE_VL_STEPS = §dVL March Steps§r
option.IRLITE_VL_MAX_DIST = §dVL Max Distance§r
option.IRLITE_VL_SHADOWS = §dShadowed Beams§r
option.IRLITE_VL_SHADOWS.comment = Per-step occlusion of the beams by the baked shadow maps - god rays through windows. Needs Baked Shadows on.
option.IRLITE_VL_SHADOW_STRIDE = §dVL Shadow Stride§r
option.IRLITE_VL_SHADOW_STRIDE.comment = Tap the shadow map every Nth march step and reuse it in between. Higher = faster, slightly coarser beams.
option.IRLITE_VL_TIP_BOOST = §dTip Glow Boost§r
option.IRLITE_VL_TIP_RADIUS = §dTip Glow Radius§r

option.IRLITE_TOON = §aToon Shading§r
option.IRLITE_TOON.comment = Quantize the IRLite diffuse into bands - a cel look.
option.IRLITE_TOON_BANDS = §aToon Bands§r
option.IRLITE_TOON_SMOOTH = §aBand Smoothing§r

option.IRLITE_OUTLINE = §eRim Outline§r
option.IRLITE_OUTLINE.comment = Light-driven contour ink: a line appears where a light wraps an object from behind or the side. A frontal light draws nothing.
option.IRLITE_OUTLINE_TARGET = §eOutline Target§r
value.IRLITE_OUTLINE_TARGET.0 = Everything
value.IRLITE_OUTLINE_TARGET.1 = Entities Only
option.IRLITE_OUTLINE_STRENGTH = §eOutline Strength§r
option.IRLITE_OUTLINE_PIXEL_SIZE = §eOutline Width (px)§r
option.IRLITE_OUTLINE_WRAP = §eLight Wrap§r
option.IRLITE_OUTLINE_WRAP.comment = How far around the object a light may sit and still ink: 0 = strict backlight, 0.5 = side and back, 1 = almost any angle.
option.IRLITE_OUTLINE_DEPTH_THRESHOLD = §eDepth Threshold§r
option.IRLITE_OUTLINE_DEPTH_THRESHOLD.comment = Relative depth-gap sensitivity of the silhouette test. Lower = more edges ink.
>>>

# --- option labels + tooltips (Russian - the pack ships ru_RU) ---
@file shaders/lang/ru_RU.lang
after "option.TRANSLUCENT_COLORED_SHADOWS.comment = §bЧто это?§r Окрашивание солнечного света через витражи. §aВЛИЯНИЕ НА ПРОИЗВОДИТЕЛЬНОСТЬ:§r среднее"
<<<

######## IRLITE LIGHTS (аддон BBS, внедряется патчером IRLite)

screen.IRLITE_SETTINGS = §6IRLite Свет§r
screen.IRLITE_SETTINGS.comment = Динамические точечные и прожекторные источники аддона IRLite для BBS - диффуз, блики, запечённые тени, объёмные лучи, тун-шейдинг и контур.
screen.IRLITE_SPECULAR_SCREEN = §bIRLite Блики§r
screen.IRLITE_SHADOW_SCREEN = §3IRLite Тени§r
screen.IRLITE_VL_SCREEN = §dIRLite Объёмный свет§r
screen.IRLITE_TOON_SCREEN = §aIRLite Тун-шейдинг§r
screen.IRLITE_OUTLINE_SCREEN = §eIRLite Контур§r

option.IRLITE_DIFFUSE = §6Диффузный свет§r
option.IRLITE_DIFFUSE.comment = Освещение поверхностей точечными и прожекторными источниками IRLite.
option.IRLITE_INTENSITY = §6Общая яркость§r
option.IRLITE_INTENSITY.comment = Главный множитель яркости всех эффектов IRLite - диффуза, бликов, объёмного света и контура.

option.IRLITE_SPECULAR = §bБлики§r
option.IRLITE_SPECULAR.comment = GGX-блики от каждого источника на энтити, руке и блок-энтити. Террейн матовый намеренно.
option.IRLITE_SPECULAR_INTENSITY = §bЯркость бликов§r
option.IRLITE_SPECULAR_SMOOTHNESS = §bГладкость бликов§r
option.IRLITE_SPECULAR_SMOOTHNESS.comment = Ширина блика. У моделей BBS нет карт материалов, поэтому отклик задаёт этот общий слайдер.

option.IRLITE_SHADOWS = §3Запечённые тени§r
option.IRLITE_SHADOWS.comment = Тени каждого источника из карт, запекаемых модом (атлас прожекторов + куб-массив точечных). Нужны также для затенённых лучей и контура.
option.IRLITE_SHADOW_QUALITY = §3Качество теней§r
option.IRLITE_SHADOW_QUALITY.comment = Число PCSS-сэмплов. 0 = один жёсткий тап, 4 = ультра-мягкие.
value.IRLITE_SHADOW_QUALITY.0 = Жёсткие (1 тап)
value.IRLITE_SHADOW_QUALITY.1 = Низкое
value.IRLITE_SHADOW_QUALITY.2 = Среднее
value.IRLITE_SHADOW_QUALITY.3 = Высокое
value.IRLITE_SHADOW_QUALITY.4 = Ультра
option.IRLITE_SHADOW_SIZE = §3Размер источника (PCSS)§r
option.IRLITE_SHADOW_SIZE.comment = Видимый размер источника для полутени. Параметр Bulb Size конкретного света в редакторе имеет приоритет.
option.IRLITE_SHADOW_BIAS = §3Депт-биас§r
option.IRLITE_SHADOW_NORMAL_OFFSET = §3Сдвиг по нормали§r
option.IRLITE_SHADOW_NORMAL_OFFSET.comment = Сдвиг приёмника вдоль нормали, прячущий лесенку глубины (акне). 0 отключает его И текстельные полы.

option.IRLITE_VOLUMETRIC = §dОбъёмный свет§r
option.IRLITE_VOLUMETRIC.comment = Лучи и дымка от каждого источника; марш идёт в редуцированном туманном пассе самого пака.
option.IRLITE_VL_INTENSITY = §dЯркость лучей§r
option.IRLITE_VL_STEPS = §dШаги марша§r
option.IRLITE_VL_MAX_DIST = §dМакс. дистанция§r
option.IRLITE_VL_SHADOWS = §dЗатенённые лучи§r
option.IRLITE_VL_SHADOWS.comment = Пошаговое затенение лучей запечёнными картами - "божественные лучи" сквозь окна. Нужны Запечённые тени.
option.IRLITE_VL_SHADOW_STRIDE = §dШаг тени в марше§r
option.IRLITE_VL_SHADOW_STRIDE.comment = Тень сэмплируется каждый N-й шаг марша, между ними переиспользуется. Больше = быстрее, чуть грубее лучи.
option.IRLITE_VL_TIP_BOOST = §dСвечение у лампы§r
option.IRLITE_VL_TIP_RADIUS = §dРадиус свечения§r

option.IRLITE_TOON = §aТун-шейдинг§r
option.IRLITE_TOON.comment = Квантование диффуза IRLite в полосы - cel-look.
option.IRLITE_TOON_BANDS = §aЧисло полос§r
option.IRLITE_TOON_SMOOTH = §aСглаживание полос§r

option.IRLITE_OUTLINE = §eКонтур (рим-инк)§r
option.IRLITE_OUTLINE.comment = Световой контур: линия появляется там, где свет огибает объект сзади или сбоку. Фронтальный свет линию не рисует.
option.IRLITE_OUTLINE_TARGET = §eЦель контура§r
value.IRLITE_OUTLINE_TARGET.0 = Всё
value.IRLITE_OUTLINE_TARGET.1 = Только энтити
option.IRLITE_OUTLINE_STRENGTH = §eСила контура§r
option.IRLITE_OUTLINE_PIXEL_SIZE = §eТолщина (px)§r
option.IRLITE_OUTLINE_WRAP = §eОхват света§r
option.IRLITE_OUTLINE_WRAP.comment = Насколько вбок может уйти свет и всё ещё рисовать линию: 0 = строго контражур, 0.5 = бок и зад, 1 = почти любой угол.
option.IRLITE_OUTLINE_DEPTH_THRESHOLD = §eПорог глубины§r
option.IRLITE_OUTLINE_DEPTH_THRESHOLD.comment = Относительная чувствительность силуэт-теста к разрыву глубины. Меньше = больше рёбер с линией.
>>>
