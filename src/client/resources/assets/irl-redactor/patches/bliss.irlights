before "  color *= vl.a*cloudAlpha ;"
<<<
  #if defined IRLITE_ACTIVE && defined IRLITE_OUTLINE
  // IRLite rim outline; inked before fog merge, hand excluded by mask 0.75.
  vec3 irliteFlatN = cross(dFdx(p3), dFdy(p3));
  if (z < 1.0) {
    float irliteOpq = irlite_decodeVec2Y(texelFetch(colortex1, ivec2(gl_FragCoord.xy), 0).a);
    if (!(abs(irliteOpq - 0.75) < 0.01)) {
      bool irliteSubject = abs(irliteOpq - 0.45) < 0.01 || isEntity;
      if (dot(irliteFlatN, p3) > 0.0) irliteFlatN = -irliteFlatN;
      color += IRLITE_INTENSITY * irlite_outlineInk(p3, irliteFlatN, irliteSubject);
    }
  }
  #endif

