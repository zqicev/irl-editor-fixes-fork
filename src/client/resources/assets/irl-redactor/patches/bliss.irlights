		#ifdef IRLITE_ACTIVE
		// IRLite point/spot lights (deferred opaque path; feetPlayerPos already bobbing-corrected).
		if (!isDHrange) {
			bool irliteNonTerrain = entities || hand;
			vec3 irlitePlayerPos = feetPlayerPos;
			vec3 irliteDiffuse = vec3(0.0);
			vec3 irliteSpec = vec3(0.0);
			irlite_lightSurface(irlitePlayerPos, slopednormal, irliteNonTerrain, irliteDiffuse, irliteSpec);
			#ifdef IRLITE_DIFFUSE
				gl_FragData[0].rgb += albedo * (IRLITE_INTENSITY * irliteDiffuse);
			#endif
			#ifdef IRLITE_SPECULAR
				gl_FragData[0].rgb += (IRLITE_INTENSITY * IRLITE_SPECULAR_INTENSITY) * irliteSpec;
			#endif
		}
