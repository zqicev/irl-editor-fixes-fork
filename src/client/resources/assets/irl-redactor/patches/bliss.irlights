>>>
replace "\tgl_FragData[0] = clamp(VolumetricFog, 0.0, 65000.0);"
<<<
	gl_FragData[0] = clamp(VolumetricFog, 0.0, 65000.0);

	#if defined IRLITE_ACTIVE && defined IRLITE_VOLUMETRIC
	// IRLite per-light VL: marched once here; re-added after the underwater overwrite.
	vec3 irliteVL = vec3(0.0);
	if (tc.x <= 1.0 && tc.y <= 1.0) {
		vec3 irliteStart = gbufferModelViewInverse[3].xyz + cameraPosition;
		vec3 irliteEnd = mat3(gbufferModelViewInverse) * viewPos0 + gbufferModelViewInverse[3].xyz + cameraPosition;
		vec3 irliteDir = irliteEnd - irliteStart;
		float irliteLen = length(irliteDir);
		if (irliteLen > 0.01) {
			irliteVL = irlite_volumetric(irliteStart, irliteEnd, irliteDir / irliteLen, noise_2);
			if (isEyeInWater == 1) irliteVL *= pow(vec3(0.80, 0.87, 0.97) * 0.55, vec3(2.0));
			if (isEyeInWater == 2) irliteVL = vec3(0.0);
		}
	}
	gl_FragData[0].rgb += irliteVL;
	#endif
